                            "query": [
                                {
                                    "key": "status",
                                    "value": "{{orderStatus}}"
                                },
                                {
                                    "key": "limit",
                                    "value": "{{limit}}"
                                },
                                {
                                    "key": "offset",
                                    "value": "{{offset}}"
                                }
                            ]
                        },
                        "description": "GET /orders/my"
                    }
                },
                {
                    "name": "Get Order Details",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}{{apiPrefix}}/orders/{{orderId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "{{apiPrefix}}",
                                "orders",
                                "{{orderId}}"
                            ]
                        },
                        "description": "GET /orders/:id"
                    }
                },
                {
                    "name": "Create Order",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"products\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"quantity\": 1\n    }\n  ],\n  \"shippingAddress\": \"123 Main St\",\n  \"notes\": \"Leave at front desk\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}{{apiPrefix}}/orders",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "{{apiPrefix}}",
                                "orders"
                            ]
                        },
                        "description": "POST /orders"
                    }
                },
                {
                    "name": "Update Order",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"status\": \"processing\",\n  \"shippingAddress\": \"123 Main St, Apt 2\",\n  \"notes\": \"Call on arrival\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}{{apiPrefix}}/orders/{{orderId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "{{apiPrefix}}",
                                "orders",
                                "{{orderId}}"
                            ]
                        },
                        "description": "PUT /orders/:id"
                    }
                }
            ]
        },
        {
            "name": "Users",
            "item": [
                {
                    "name": "Get User Profile",
                    "request": {
