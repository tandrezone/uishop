                            ]
                        },
                        "description": "PUT /users/profile"
                    }
                }
            ]
        }
    ],
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:8000"
        },
        {
            "key": "apiPrefix",
            "value": ""
        },
        {
            "key": "token",
            "value": ""
        },
        {
            "key": "productId",
            "value": "1"
        },
        {
            "key": "orderId",
            "value": "1"
        },
        {
            "key": "search",
