# UIShop Backend API Configuration

# Database - Choose MySQL or SQLite
# For MySQL:
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=uishop
DB_USER=root
DB_PASS=

# For SQLite (uncomment below and comment out MySQL above):
# DB_DRIVER=sqlite
# DB_FILE=data/uishop.db

# JWT
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRY=86400

# API
API_BASE_URL=http://localhost:8000

# Environment
APP_ENV=development
APP_DEBUG=true
