# UIShop Backend API Configuration - SQLite Version

# Database - SQLite (Zero Configuration!)
DB_DRIVER=sqlite
DB_FILE=data/uishop.db

# JWT
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRY=86400

# API
API_BASE_URL=http://localhost:8000

# Environment
APP_ENV=development
APP_DEBUG=true
